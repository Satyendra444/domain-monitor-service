# Domain Monitor Service - Environment Configuration
# Copy this file to .env and configure with your actual values

# ======================================
# SMTP EMAIL CONFIGURATION (Required)
# ======================================
# SMTP server configuration - Gmail example shown
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your email credentials
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ======================================
# EMAIL RECIPIENTS (Required)
# ======================================
# Primary recipients for domain alerts (comma-separated for multiple)
TO_EMAIL=primary-recipient@yourdomain.com,another-recipient@yourdomain.com

# Secondary recipients (CC) - optional but recommended (comma-separated for multiple)
CC_EMAIL=secondary-recipient@yourdomain.com,manager@yourdomain.com

# ======================================
# MONITORING CONFIGURATION (Optional)
# ======================================
# How often to check domains (in minutes)
CHECK_INTERVAL_MINUTES=10

# ======================================
# SERVICE CONFIGURATION (Optional)
# ======================================
# Display name for the monitoring service
SERVICE_NAME=Domain Monitor Service

# Logging level: ERROR, WARN, INFO, DEBUG
# ERROR: Only critical errors and alerts
# WARN: Warnings and errors  
# INFO: Normal operation messages (default)
# DEBUG: Detailed debugging information
LOG_LEVEL=INFO

# ======================================
# SETUP NOTES
# ======================================
# 
# For Gmail users:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an App Password:
#    - Go to Google Account settings
#    - Security → 2-Step Verification → App passwords
#    - Generate password for "Mail"
# 3. Use the generated app password as SMTP_PASS
#
# For other email providers:
# - Update SMTP_HOST and SMTP_PORT accordingly
# - Some providers may require different security settings
#
# Multiple Email Recipients:
# - Separate multiple email addresses with commas
# - Example: TO_EMAIL=user1@domain.com,user2@domain.com,user3@domain.com
# - Spaces around commas are automatically trimmed
#
# Logging Levels:
# - ERROR: Minimal logging, only failures and alerts
# - WARN: Error + warning messages
# - INFO: Normal operational messages (recommended)
# - DEBUG: Verbose logging for troubleshooting
#
# Security Notes:
# - Never commit the actual .env file to version control
# - Use strong, unique passwords
# - Consider using a dedicated email account for monitoring
